{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cluster.example/schemas/correlation-contract.schema.json",
  "title": "Canonical Decision Correlation Contract",
  "type": "object",
  "required": [
    "decision_correlation_id",
    "scenario_id",
    "created_at",
    "actor",
    "requested_action",
    "context",
    "expected_layers"
  ],
  "properties": {
    "decision_correlation_id": {
      "type": "string",
      "description": "Stable identifier carried by every primitive artifact for independent audit stitching."
    },
    "scenario_id": { "type": "string" },
    "created_at": { "type": "string", "format": "date-time" },
    "actor": { "type": "object" },
    "requested_action": { "type": "object" },
    "context": { "type": "object" },
    "evidence_refs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "expected_layers": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["ASRO", "FlowSignal", "MIR", "EVIDE", "Reviewability"]
      }
    }
  }
}
